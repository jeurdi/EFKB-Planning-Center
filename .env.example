# Microsoft Entra ID (Azure AD) — get these from Azure Portal > App Registrations
# https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps/ApplicationsListBlade
AZURE_AD_CLIENT_ID=your-client-id-here
AZURE_AD_CLIENT_SECRET=your-client-secret-here
AZURE_AD_TENANT_ID=your-tenant-id-here

# NextAuth secret — generate with: openssl rand -base64 32
AUTH_SECRET=your-random-secret-here

# Your app URL (for local dev use http://localhost:3000)
NEXTAUTH_URL=http://localhost:3000

# Shared mailbox address used as the sender for service invitations
# The logged-in user must have "Send As" permission on this mailbox (set in M365 Admin Center)
SHARED_MAILBOX=planung@your-domain.de

# MariaDB connection
DB_HOST=localhost
DB_PORT=3306
DB_USER=planungstool
DB_PASSWORD=your-db-password-here
DB_NAME=planungstool

# Set to false (or remove) in production — enables real Microsoft auth
DEV_SKIP_AUTH=false
NEXT_PUBLIC_DEV_SKIP_AUTH=false
